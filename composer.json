{
    "name": "hamedelasma/entra-sync",
    "description": "Sync users from Microsoft Entra ID to Laravel database",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "illuminate/support": "^12.0 || ^13.0",
        "illuminate/console": "^12.0 || ^13.0",
        "illuminate/http": "^12.0 || ^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "pestphp/pest": "^3.0",
        "laravel/pint": "^1.27"
    },
    "autoload": {
        "psr-4": {
            "HamedElasma\\EntraSync\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "HamedElasma\\EntraSync\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "HamedElasma\\EntraSync\\EntraSyncServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
